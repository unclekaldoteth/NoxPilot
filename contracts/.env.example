# Public Arbitrum Sepolia RPC. Replace with a private provider if you want
# higher rate limits for broadcast and app reads.
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Funded deployer used by forge script/Deploy.s.sol:Deploy.
PRIVATE_KEY=

# Vault admin and isolated operator wallet.
OWNER_ADDRESS=
EXECUTION_WALLET_ADDRESS=

# Demo defaults: Circle test USDC routed through Uniswap V3 SwapRouter02.
SESSION_ASSET_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d
SWAP_ROUTER_ADDRESS=0x101F443B4d1b059569D643917553c771E1b9663E
DEFAULT_POOL_FEE=3000

# Existing live ExecutionGuard used by the wrapper-only deployment path.
EXECUTION_GUARD_ADDRESS=

# Optional wrapper deployments for supported acquired ERC-20s on Arbitrum Sepolia.
TOKEN_ETH_ADDRESS=0x980B62Da83eFf3D4576C647993b0c1D7faf17c73
TOKEN_ARB_ADDRESS=
TOKEN_LINK_ADDRESS=0xb1D4538B4571d411F07960EF2838Ce337FE1E80E
