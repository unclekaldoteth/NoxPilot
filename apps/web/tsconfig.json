{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@noxpilot/nox-sdk": [
        "../../packages/nox-sdk"
      ],
      "@noxpilot/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@noxpilot/ui": [
        "../../packages/ui/src/index.tsx"
      ]
    },
    "incremental": true,
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
